  "name": "gdp",
  "views": [
    {
      "name": "top-economies",
      "title": "GDP of the World's 10 Largest Economies (2000–2022)",
      "description": "GDP in current USD for the top 10 economies since 2000. The US held a commanding lead throughout, while China's rapid ascent — from $1.2T in 2000 to $17.9T in 2022 — is the defining economic shift of the century. India overtook the UK and France in the early 2020s.",
      "resources": ["top-economies"],
      "specType": "plot",
      "spec": {
        "height": 460,
        "marginLeft": 65,
        "marginRight": 20,
        "x": { "label": "Year", "tickFormat": ".0f" },
        "y": { "label": "GDP (USD Trillion)", "grid": true },
        "color": { "legend": true },
        "marks": [
          {
            "type": "line",
            "x": "year", "y": "gdp_trillion", "stroke": "country",
            "strokeWidth": 2, "tip": true
          }
        ]
      }
    }
  ],
  "resources": [
    {
      "name": "top-economies",
      "path": "data/top-economies.csv",
      "format": "csv",
      "mediatype": "text/csv",
      "schema": {
        "fields": [
          { "name": "country", "type": "string" },
          { "name": "year", "type": "integer" },
          { "name": "gdp_trillion", "type": "number", "description": "GDP in current USD trillions" }
        ]
      }
    },
    {
      "name": "gdp",
      "path": "data/gdp.csv",
      "schema": {
        "fields": [
          {
            "name": "Country Name",
            "type": "string"
          },
          {
            "name": "Country Code",
            "type": "string"
          },
          {
            "name": "Year",
            "type": "year"
          },
          {
            "description": "GDP in current USD",
            "name": "Value",
            "type": "number"
          }
        ]
      }
    }
  ],
  "sources": [
    {
      "name": "World Bank and OECD",
